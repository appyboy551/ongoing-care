# Copy to .env.local for local dev. Do not commit .env or .env.local.

# Postgres connection string. Use Vercel Postgres or Neon for production.
DATABASE_URL="postgresql://user:password@localhost:5432/ongoing_care?schema=public"

# Resend API key for transactional email. Get one at https://resend.com (free tier covers MVP).
RESEND_API_KEY=""
# From-address Resend will send on behalf of. Must be a verified domain or onboarding@resend.dev for testing.
EMAIL_FROM="Ongoing Care <onboarding@resend.dev>"

# ClickSend SMS. Used only for urgent events (missed-check-in escalation).
# Sign up at https://clicksend.com, top up credit (~$5 is plenty for months),
# then grab the username and API key from Dashboard > Developers > API credentials.
# Leave empty to disable SMS; the escalation will still send emails.
# Australian sends are roughly $0.085 AUD per message. Max 4 per event.
CLICKSEND_USERNAME=""
CLICKSEND_API_KEY=""

# Session secret. Generate with: openssl rand -base64 32
SESSION_SECRET=""

# Portal encryption key, used to encrypt Medicare and Medibank numbers at rest.
# Generate with: openssl rand -base64 32
# IMPORTANT: back this key up somewhere safe (e.g., your Bitwarden vault) before
# you store any numbers. If you lose this key, the encrypted values cannot be
# recovered.
PORTAL_ENCRYPTION_KEY=""

# Cron secret. Vercel Cron sends this as a Bearer token to /api/cron/* routes.
# Without this, the missed-check-in cron cannot run.
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# Anthropic API key. Used by the brain-dump-to-draft helper at /admin/draft-helper.
# Get one at https://console.anthropic.com. Optional: if unset, the draft helper
# returns an error explaining what to do. The rest of the portal works fine.
ANTHROPIC_API_KEY=""

# Public app URL. Used in email links. Defaults to http://localhost:3001 in dev,
# so it doesn't collide with the EatClub project running on 3000.
APP_URL="http://localhost:3001"

# Admin (David) email. The only address allowed to access /admin routes.
ADMIN_EMAIL="david.jwalker5@gmail.com"
